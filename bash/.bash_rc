# The above should be the last lines before jumping into this file
# copying for usage in new env


# Setup fzf
# ---------
if [[ ! "$PATH" == ${HOME}/.fzf/bin* ]]; then
  PATH="${PATH:+${PATH}:}${HOME}/.fzf/bin"
  eval "$(fzf --bash)"
fi

shopt -s histappend
PROMPT_COMMAND="history -a;$PROMPT_COMMAND"

source "$DOTFILES_DIR/bash/.bash_aliases"
source "$DOTFILES_DIR/bash/.bash_prompt"
